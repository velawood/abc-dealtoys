---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.svelte';
---

<BaseLayout
  title="Contact Us"
  description="Get a quote for custom deal toys. Tell us about your deal and we'll craft something extraordinary."
>
  <!-- Hero -->
  <section class="bg-navy py-20 text-center">
    <div class="container">
      <h1 class="font-baskervville text-4xl font-semibold text-gold sm:text-5xl">Get a Quote</h1>
      <p class="mt-4 text-lg text-white/70 max-w-xl mx-auto">
        Tell us about your deal and we'll craft something extraordinary.
      </p>
    </div>
  </section>

  <!-- Form section -->
  <section class="bg-white py-16">
    <div class="container">
      <ContactForm client:load />
    </div>
  </section>

  <!-- Alternative contact -->
  <section class="bg-white pb-16">
    <div class="container text-center">
      <p class="text-sm text-slate/60">
        Prefer email? Reach us at
        <a href="mailto:info@abcdealtoys.com" class="text-navy underline underline-offset-2 hover:text-gold transition-colors">
          info@abcdealtoys.com
        </a>
      </p>
    </div>
  </section>
</BaseLayout>
